generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  createdAt  DateTime @default(now())
  assistants Assistant[]
}

model Assistant {
  id           String   @id @default(uuid())
  name         String
  systemPrompt String   @default("")
  model        String   @default("mistral")
  userId       String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  documents    Document[]
  apiKeys      ApiKey[]
  chats        Chat[]
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  keyHash     String
  assistantId String
  createdAt   DateTime @default(now())

  assistant Assistant @relation(fields: [assistantId], references: [id])
}

model Chat {
  id          String   @id @default(uuid())
  assistantId String
  createdAt   DateTime @default(now())

  assistant Assistant @relation(fields: [assistantId], references: [id])
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id])
}

model Lead {
  id        String   @id @default(cuid())
  email     String?
  source    String?
  createdAt DateTime @default(now())
}

model Document {
  id          String    @id @default(uuid())
  title       String
  content     String
  type        String
  assistantId String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  assistant Assistant       @relation(fields: [assistantId], references: [id])
  chunks    DocumentChunk[]
}

model DocumentChunk {
  id         String   @id @default(uuid())
  content    String
  documentId String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])
}
